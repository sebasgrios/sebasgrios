# La config PÚBLICA (URL del sitio, URL + anon key de Supabase, token de
# Cloudflare Web Analytics) NO se lee de env: vive en src/config/* como fuente
# única de verdad. Motivo: Cloudflare Pages no expone estas vars durante el
# `astro build` (prerender), lo que rompía el deploy. Son valores públicos
# (anon key protegida por RLS, beacon token público). Ver docs/12-deployment.md.

# Secretos del backoffice SSR (/admin). Opcionales en local.
SUPABASE_SERVICE_ROLE_KEY=
SESSION_SECRET=
# Cloudflare Pages deploy hook que dispara "Publicar" (/admin/publish).
CF_DEPLOY_HOOK_URL=
