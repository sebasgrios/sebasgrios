---
import AdminField from '@/components/admin/AdminField.astro';

interface Props {
  label: string;
  name: string;
  es?: string;
  en?: string;
  multiline?: boolean;
  required?: boolean;
}

const { label, name, es = '', en = '', multiline = false, required = true } = Astro.props;
---

<fieldset class="border border-hairline rounded-2xl p-4">
  <legend class="px-2 text-[0.8rem] font-semibold">{label}</legend>
  <div class="grid gap-3 sm:grid-cols-2">
    <AdminField
      label="Español"
      name={`${name}.es`}
      value={es}
      multiline={multiline}
      required={required}
    />
    <AdminField
      label="English"
      name={`${name}.en`}
      value={en}
      multiline={multiline}
      required={required}
    />
  </div>
</fieldset>
