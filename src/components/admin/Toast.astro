---
interface Props {
  status: string | null;
}

const { status } = Astro.props;

const MESSAGES = {
  ok: { type: 'success', message: 'Cambios guardados.' },
  invalid: { type: 'error', message: 'Revisa los campos: algún dato falta o no es válido.' },
  error: { type: 'error', message: 'No se pudo guardar. Inténtalo de nuevo.' },
} as const;

const toast = status && status in MESSAGES ? MESSAGES[status as keyof typeof MESSAGES] : null;
---

{
  toast && (
    <div
      id="admin-toast"
      class="admin-toast glass"
      data-type={toast.type}
      role="status"
      aria-live="polite"
    >
      <span class="admin-toast-dot" aria-hidden="true" />
      <span>{toast.message}</span>
    </div>
  )
}

<style is:global>
  .admin-toast {
    position: fixed;
    top: 18px;
    left: 50%;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 10px;
    max-width: calc(100% - 32px);
    padding: 12px 20px;
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 500;
    transform: translate(-50%, -18px);
    opacity: 0;
    transition: opacity 0.35s var(--ease-out), transform 0.35s var(--ease-out);
  }
  .admin-toast[data-show="true"] {
    transform: translate(-50%, 0);
    opacity: 1;
  }
  .admin-toast-dot {
    width: 9px;
    height: 9px;
    flex-shrink: 0;
    border-radius: 9999px;
    background: oklch(0.72 0.2 150);
  }
  .admin-toast[data-type="error"] .admin-toast-dot {
    background: oklch(0.62 0.2 25);
  }
  @media (prefers-reduced-motion: reduce) {
    .admin-toast {
      transition: opacity 0.2s ease;
      transform: translate(-50%, 0);
    }
  }
</style>
