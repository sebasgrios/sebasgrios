---
import AdminField from '@/components/admin/AdminField.astro';
import AdminLocalized from '@/components/admin/AdminLocalized.astro';
import AdminLocalizedList from '@/components/admin/AdminLocalizedList.astro';
import AdminSelect from '@/components/admin/AdminSelect.astro';
import AdminTechPicker from '@/components/admin/AdminTechPicker.astro';
import type { RoleAdmin } from '@/lib/data/repos';
import type { Technology } from '@/lib/domain/types';

interface Props {
  role: RoleAdmin | null;
  companyId: string;
  technologies: Technology[];
  nextSort: number;
}

const { role, companyId, technologies, nextSort } = Astro.props;
const r = role;
const modeOptions = [
  { value: 'remote', label: 'Remoto' },
  { value: 'onsite', label: 'Presencial' },
  { value: 'hybrid', label: 'Híbrido' },
];
---

<input type="hidden" name="companyId" value={companyId} />
<AdminLocalized label="Puesto" name="title" es={r?.title.es} en={r?.title.en} />
<AdminLocalized label="Sector" name="sector" es={r?.sector.es} en={r?.sector.en} />
<AdminLocalized label="Modalidad (etiqueta visible)" name="mode" es={r?.mode.es} en={r?.mode.en} />
<div class="grid gap-3 sm:grid-cols-2">
  <AdminSelect
    label="Modalidad (icono)"
    name="modeKey"
    options={modeOptions}
    value={r?.modeKey ?? 'remote'}
    required
  />
  <AdminField label="Orden" name="sortOrder" type="number" value={String(r?.sortOrder ?? nextSort)} />
  <AdminField label="Inicio" name="startDate" type="date" value={r?.startDate} required />
  <AdminField label="Fin (vacío = actualidad)" name="endDate" type="date" value={r?.endDate} />
</div>
<AdminLocalized
  label="Descripción"
  name="description"
  es={r?.description.es}
  en={r?.description.en}
  multiline
/>
<AdminLocalizedList label="Bullets" name="bullets" items={r?.bullets ?? []} />
<AdminTechPicker technologies={technologies} selected={r?.technologyIds ?? []} />
