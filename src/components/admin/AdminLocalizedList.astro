---
import AdminLocalized from '@/components/admin/AdminLocalized.astro';

interface Props {
  label: string;
  name: string;
  items: { es: string; en: string }[];
  slots?: number;
}

const { label, name, items, slots = 8 } = Astro.props;
const rows = Array.from({ length: slots }, (_, index) => items[index] ?? { es: '', en: '' });
---

<div class="flex flex-col gap-3">
  <span class="text-[0.8rem] font-medium text-text-soft">{label}</span>
  {
    rows.map((row, index) => (
      <AdminLocalized
        label={`#${index + 1}`}
        name={`${name}.${index}`}
        es={row.es}
        en={row.en}
        required={false}
      />
    ))
  }
</div>
