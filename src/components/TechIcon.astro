---
import { getTechIcon } from '@/lib/icons/techIconRegistry';

interface Props {
  slug: string;
  label: string;
  size?: number;
}

const { slug, label, size = 36 } = Astro.props;
const icon = getTechIcon(slug);
const isStroke = icon?.kind === 'stroke';
---

{
  icon ? (
    <span
      class="tech-icon"
      data-tooltip={label}
      style={`--tech-icon-size:${size}px`}
      tabindex="0"
      role="img"
      aria-label={label}
    >
      <svg
        viewBox={icon.viewBox ?? '0 0 24 24'}
        fill={isStroke ? 'none' : 'currentColor'}
        stroke={isStroke ? 'currentColor' : undefined}
        stroke-width={isStroke ? 1.9 : undefined}
        stroke-linecap={isStroke ? 'round' : undefined}
        stroke-linejoin={isStroke ? 'round' : undefined}
        aria-hidden="true"
        set:html={icon.inner}
      />
    </span>
  ) : (
    <span class="tag-pill">{label}</span>
  )
}
