---
import SunIcon from '@/components/icons/Sun.astro';
import MoonIcon from '@/components/icons/Moon.astro';
---

<button aria-label='Cambiar tema' class='flex items-center' data-theme-toggle type='button'>
  <SunIcon class='block fill-gray-800 dark:hidden size-8' />
  <MoonIcon class='dark:block fill-gray-100 hidden size-8' />
</button>

<script>
  const getPreferredTheme = () => {
    if (localStorage.theme === 'dark') {
      return 'dark';
    }

    if (localStorage.theme === 'light') {
      return 'light';
    }

    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };

  const applyTheme = (theme: 'dark' | 'light') => {
    document.documentElement.classList.toggle('dark', theme === 'dark');
  };

  const bindThemeToggle = () => {
    const themeButton = document.querySelector('[data-theme-toggle]');

    if (!(themeButton instanceof HTMLButtonElement) || themeButton.dataset.bound === 'true') {
      return;
    }

    themeButton.dataset.bound = 'true';
    themeButton.addEventListener('click', () => {
      const nextTheme = getPreferredTheme() === 'dark' ? 'light' : 'dark';
      localStorage.setItem('theme', nextTheme);
      applyTheme(nextTheme);
    });
  };

  applyTheme(getPreferredTheme());
  bindThemeToggle();
  document.addEventListener('astro:page-load', bindThemeToggle);
</script>
