---
interface Props {
  href?: string;
  ariaLabel: string;
  title?: string;
  class?: string;
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
}

const {
  href,
  ariaLabel,
  title,
  class: className = '',
  type = 'button',
  target,
  rel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={`icon-btn ${className}`}
  href={href}
  type={href ? undefined : type}
  aria-label={ariaLabel}
  title={title ?? ariaLabel}
  target={target}
  rel={rel}
>
  <slot />
</Tag>

<style is:global>
  .icon-btn {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    color: var(--text);
    cursor: pointer;
    transition:
      transform 0.4s var(--ease),
      color 0.25s,
      background 0.25s;
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    text-decoration: none;
  }
  .icon-btn:hover {
    color: var(--accent);
    transform: rotate(-12deg) scale(1.06);
  }
  .icon-btn svg {
    width: 18px;
    height: 18px;
  }
</style>
