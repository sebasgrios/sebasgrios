---
interface Props {
  href?: string;
  ariaLabel: string;
  title?: string;
  class?: string;
  type?: 'button' | 'submit';
  target?: string;
  rel?: string;
}

const {
  href,
  ariaLabel,
  title,
  class: className = '',
  type = 'button',
  target,
  rel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class={`icon-btn ${className}`}
  href={href}
  type={href ? undefined : type}
  aria-label={ariaLabel}
  title={title ?? ariaLabel}
  target={target}
  rel={rel}
>
  <slot />
</Tag>
