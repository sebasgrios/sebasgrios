---
import { Image } from 'astro:assets';

import { TECHNOLOGY_LABELS } from '@/data/technologies';
import TechnologyIcon from '@/components/Technology-Icon.astro';
import Tooltip from '@/components/Tooltip.astro';
import WorldIcon from '@/components/icons/World.astro';
import CodeIcon from '@/components/icons/Code.astro';
import type { ProjectEntry } from '@/types/content';

interface Props {
  project: ProjectEntry;
}

const { project } = Astro.props;
const { title, description, image, technologies, liveUrl, codeUrl } = project;
const previewUrl = liveUrl ?? codeUrl;
---

<article class='flex flex-col sm:flex-row gap-2 sm:gap-4'>
  <div class='flex flex-1 flex-col'>
    <a
      aria-label={`Abrir proyecto ${title}`}
      class='bg-white dark:bg-[var(--dark-surface)] border-gray-200 dark:border-[var(--dark-border)] group overflow-hidden relative rounded-xl shadow-xl' 
      href={previewUrl}
      rel='noopener noreferrer'
      target='_blank'
    >
      <Image 
        alt=`Captura del proyecto ${title}` 
        class='duration-500 h-full rounded-lg hover:scale-110' 
        src={image}
      />
    </a>
  </div>
  <div class='flex-1 flex flex-col gap-1 md:gap-2 py-2'>
    <h2 class='font-semibold text-2xl text-gray-600 dark:text-[var(--dark-text)]'>
      {title}
    </h2>
    <p class='font-medium text-lg text-gray-400 dark:text-[var(--dark-text-muted)]'>{description}</p>
    <div class='flex flex-row gap-2 items-center justify-start'>
       {technologies.map((technology) => (
         <Tooltip description={TECHNOLOGY_LABELS[technology]}>
          <TechnologyIcon class='size-8' technology={technology} />
         </Tooltip>
       ))}
    </div>
    <div class='flex flex-row gap-2 items-center justify-start'>
      {liveUrl && (
        <a 
          class='bg-gray-800 hover:bg-gray-700 dark:bg-[var(--dark-surface-strong)] hover:dark:bg-neutral-800 flex flex-row font-semibold gap-2 group items-center px-4 py-2 rounded-xl shadow-md text-white dark:text-[var(--dark-text)] text-xl' 
          href={liveUrl}
          rel='noopener noreferrer'
          target='_blank'
        >
         Live <WorldIcon class='duration-200 xl:rotate-12 group-hover:rotate-0 size-6 stroke-white dark:stroke-[var(--dark-text)]' />
        </a>
      )}
      {codeUrl && (
        <a 
          class='bg-gray-800 hover:bg-gray-700 dark:bg-[var(--dark-surface-strong)] hover:dark:bg-neutral-800 flex flex-row font-semibold gap-2 group items-center px-4 py-2 rounded-xl shadow-md text-white dark:text-[var(--dark-text)] text-xl' 
          href={codeUrl}
          rel='noopener noreferrer'
          target='_blank'
        >
         Code <CodeIcon class='duration-200 xl:rotate-12 group-hover:rotate-0 size-6 stroke-white dark:stroke-[var(--dark-text)]' />
        </a>
      )}
    </div>
  </div>
</article>
