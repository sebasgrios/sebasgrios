---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  as?: keyof HTMLElementTagNameMap;
  interactive?: boolean;
}

const { as: Tag = 'div', interactive = false, class: className, ...rest } = Astro.props;
const classes = ['glass', interactive ? 'interactive' : '', className].filter(Boolean).join(' ');
---

<Tag class={classes} data-glass-interactive={interactive ? 'true' : undefined} {...rest}>
  <slot />
</Tag>
