---
import { Image } from 'astro:assets';
import avatar from '@/assets/sebas.png';
import type { Locale } from '@/config/site';
import { navigation } from '@/config/navigation';
import { useTranslations } from '@/i18n';
import Icon from './Icon.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<header class="header" data-header>
  <div class="header__inner">
    <a href={`#${navigation[0].id}`} class="brand" aria-label={`${t('nav.home')} — SebasGRios`}>
      <span class="brand__avatar">
        <Image src={avatar} alt="" width={68} height={68} loading="eager" />
      </span>
      <span>Sebas</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        navigation.map((n) => (
          <a href={`#${n.id}`} class="nav__link" data-nav-link={n.id}>
            {t(n.key)}
          </a>
        ))
      }
    </nav>

    <div class="header__actions">
      <button
        type="button"
        class="icon-btn theme"
        aria-label={t('a11y.theme')}
        title={t('a11y.theme')}
        data-theme-toggle
      >
        <span class="theme-icon theme-icon--moon"><Icon name="moon" size={18} /></span>
        <span class="theme-icon theme-icon--sun"><Icon name="sun" size={18} /></span>
      </button>
      <button
        type="button"
        class="icon-btn hamburger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t('a11y.menu')}
        data-menu-toggle
      >
        <Icon name="menu" size={18} />
      </button>
    </div>
  </div>
</header>

<nav id="mobile-menu" class="mobile-menu" aria-label="Mobile" aria-hidden="true" data-mobile-menu>
  {
    navigation.map((n, i) => (
      <a href={`#${n.id}`} data-menu-link tabindex="-1">
        <span class="idx">0{i + 1}</span>
        {t(n.key)}
      </a>
    ))
  }
</nav>

<script>
  const header = document.querySelector<HTMLElement>('[data-header]');
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  const navLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]')];

  // Theme toggle (vanilla — avoids shipping a framework runtime for one button).
  const themeBtn = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const THEME_COLOR = { light: '#fcfcfc', dark: '#27272e' } as const;
  const applyTheme = (theme: 'light' | 'dark') => {
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('sgr-theme', theme);
    document.querySelector('meta[name="theme-color"]')?.setAttribute('content', THEME_COLOR[theme]);
  };
  themeBtn?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });
  // Follow the system preference until the user chooses manually.
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    if (!localStorage.getItem('sgr-theme')) {
      document.documentElement.setAttribute('data-theme', e.matches ? 'dark' : 'light');
    }
  });

  // Header: shadow once scrolled, hide on scroll-down / reveal on scroll-up.
  let lastY = 0;
  // While the user navigates via an in-page anchor, the smooth scroll travels
  // downward and would otherwise hide the header. Lock it visible until the
  // scroll settles (no scroll event for a short window).
  let navLock = false;
  let navLockTimer: number | undefined;
  const releaseNavLock = () => {
    clearTimeout(navLockTimer);
    navLockTimer = window.setTimeout(() => {
      navLock = false;
    }, 150);
  };
  const lockNav = () => {
    navLock = true;
    releaseNavLock();
  };
  const onScroll = () => {
    const y = window.scrollY;
    header?.classList.toggle('is-scrolled', y > 24);
    if (menu?.classList.contains('is-open')) {
      lastY = y;
      return;
    }
    if (navLock) {
      header?.classList.remove('is-hidden');
      lastY = y;
      releaseNavLock();
      return;
    }
    header?.classList.toggle('is-hidden', y > lastY && y > 200);
    lastY = y;
  };
  window.addEventListener('scroll', onScroll, { passive: true });

  // Keep the header pinned during anchor navigation (header nav, brand, menu).
  for (const a of document.querySelectorAll<HTMLAnchorElement>(
    '[data-header] a[href^="#"], [data-mobile-menu] a[href^="#"]',
  )) {
    a.addEventListener('click', lockNav);
  }

  // Mobile menu open/close.
  const menuLinks = menu ? [...menu.querySelectorAll<HTMLAnchorElement>('[data-menu-link]')] : [];
  const setMenu = (open: boolean) => {
    menu?.classList.toggle('is-open', open);
    menu?.setAttribute('aria-hidden', String(!open));
    toggle?.setAttribute('aria-expanded', String(open));
    // Keep hidden menu links out of the tab order (aria-hidden must not wrap
    // focusable content).
    for (const link of menuLinks) link.tabIndex = open ? 0 : -1;
  };
  toggle?.addEventListener('click', () => setMenu(!menu?.classList.contains('is-open')));
  menu?.querySelectorAll('[data-menu-link]').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setMenu(false);
  });

  // Active section highlight.
  const io = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const id = entry.target.id;
        for (const link of navLinks) {
          const active = link.dataset.navLink === id;
          link.classList.toggle('is-active', active);
          if (active) link.setAttribute('aria-current', 'true');
          else link.removeAttribute('aria-current');
        }
      }
    },
    { rootMargin: '-45% 0px -50% 0px', threshold: 0 },
  );
  for (const link of navLinks) {
    const section = document.getElementById(link.dataset.navLink ?? '');
    if (section) io.observe(section);
  }
</script>
