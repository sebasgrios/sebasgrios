---
import { Image } from 'astro:assets';

import Avatar from '@/images/avatar.webp';
import ThemeToggle from '@/components/Theme-Toggle.astro';
---

<header class='backdrop-blur-lg sticky top-0 z-10 mx-auto flex max-w-3xl items-center justify-between px-4 py-2'>
  <div class='duration-200 flex flex-row gap-2 items-center justify-left opacity-0 transition -translate-y-full' data-header-avatar>
    <Image alt='Avatar de perfil de Sebastián' class='bg-clip-padding rounded-full border-4 border-white bg-gray-200 shadow-lg size-12 dark:border-[#111111] dark:bg-[var(--dark-surface-soft)]' src={Avatar} />
    <span class='font-semibold text-gray-800 dark:text-white text-lg [text-shadow:0_1px_10px_rgba(255,255,255,0.85),0_1px_2px_rgba(0,0,0,0.22)] dark:[text-shadow:0_1px_10px_rgba(0,0,0,0.45),0_1px_2px_rgba(0,0,0,0.35)]'>Sebas</span>
  </div>
  <ThemeToggle />
</header>

<script>
  const bindHeaderAvatar = () => {
    const avatar = document.querySelector('[data-header-avatar]');
    const trigger = document.querySelector('[data-header-avatar-trigger]');

    if (!(avatar instanceof HTMLElement) || !(trigger instanceof HTMLElement)) {
      return;
    }

    if (avatar.dataset.bound === 'true') {
      return;
    }

    avatar.dataset.bound = 'true';

    const observer = new IntersectionObserver(
      ([entry]) => {
        const isVisible = entry?.isIntersecting ?? false;
        avatar.classList.toggle('opacity-0', isVisible);
        avatar.classList.toggle('-translate-y-full', isVisible);
      },
      {
        threshold: 0.2
      }
    );

    observer.observe(trigger);
  };

  bindHeaderAvatar();
  document.addEventListener('astro:page-load', bindHeaderAvatar);
</script>
