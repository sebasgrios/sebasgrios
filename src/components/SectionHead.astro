---
interface Props {
  num: string;
  eyebrow: string;
  title: string;
  sub?: string;
  id?: string;
}

const { num, eyebrow, title, sub, id } = Astro.props;
---

<div class="mb-[clamp(32px,5vw,56px)] max-w-[640px]" id={id}>
  <div
    class="reveal inline-flex items-center gap-1 font-mono text-[0.72rem] font-medium uppercase tracking-[0.22em] text-text-faint"
  >
    <span class="text-accent">{num}</span>&nbsp;/&nbsp;{eyebrow}
  </div>
  <h2
    class="reveal mt-3 font-display text-[clamp(1.9rem,4.5vw,3rem)] font-bold leading-[1.05] tracking-[-0.02em] [transition-delay:0.08s]"
  >
    {title}
  </h2>
  {
    sub && (
      <p
        class="reveal mt-3.5 max-w-[56ch] text-[1.05rem] text-text-soft text-pretty [transition-delay:0.16s]"
      >
        {sub}
      </p>
    )
  }
</div>
