---
import Glass from '@/components/Glass.astro';
import TechIcon from '@/components/TechIcon.astro';
import Building from '@/components/icons/Building.astro';
import Home from '@/components/icons/Home.astro';
import Laptop from '@/components/icons/Laptop.astro';
import Layers from '@/components/icons/Layers.astro';
import type { Locale } from '@/config/i18n';
import { formatDateRange } from '@/lib/domain/dates';
import { pickLocale, pickLocaleArray } from '@/lib/domain/i18n';
import type { ModeKey, Role } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  role: Role;
  single: boolean;
}

const { locale, role, single } = Astro.props;

const modeIcons: Record<ModeKey, typeof Home> = {
  remote: Home,
  onsite: Building,
  hybrid: Laptop,
};
const ModeIcon = modeIcons[role.modeKey];

const title = pickLocale(role.title, locale);
const sector = pickLocale(role.sector, locale);
const mode = pickLocale(role.mode, locale);
const description = pickLocale(role.description, locale);
const bullets = pickLocaleArray(role.bullets, locale);
const dateRange = formatDateRange(role.startDate, role.endDate, locale);
---

<Glass
  as="article"
  interactive
  class={`reveal role-card-base ${single ? 'pl-[clamp(20px,3vw,30px)]' : ''}`}
>
  {
    !single && (
      <span
        class="role-node absolute -left-[29px] top-7 w-3 h-3 rounded-full bg-accent shadow-[0_0_0_4px_var(--bg),0_0_14px_oklch(0.7_0.18_var(--accent-h)/0.7)] max-[720px]:-left-[22px]"
        aria-hidden="true"
      />
    )
  }
  <div class="flex flex-wrap items-baseline justify-between gap-y-2 gap-x-4">
    <div class="font-display font-bold text-[1.2rem]">{title}</div>
    <div
      class="font-mono text-[0.78rem] text-accent whitespace-nowrap max-[460px]:w-full"
    >
      {dateRange}
    </div>
  </div>
  <div
    class="flex flex-wrap gap-y-2 gap-x-3.5 mt-1.5 text-[0.84rem] text-text-faint"
  >
    <span class="inline-flex items-center gap-1.5"><Layers size={13} /> {sector}</span>
    <span class="inline-flex items-center gap-1.5"><ModeIcon size={13} /> {mode}</span>
  </div>
  <p class="text-text mt-4 text-base text-pretty">{description}</p>
  {bullets.length > 0 && <ul class="role-bullet-list">{bullets.map((b) => <li>{b}</li>)}</ul>}
  {
    role.technologies.length > 0 && (
      <div class="flex flex-wrap gap-2.5 mt-[18px]">
        {role.technologies.map((t) => (
          <TechIcon slug={t.key} label={t.label} />
        ))}
      </div>
    )
  }
</Glass>
