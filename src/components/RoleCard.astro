---
import Glass from '@/components/Glass.astro';
import Tag from '@/components/Tag.astro';
import Building from '@/components/icons/Building.astro';
import Home from '@/components/icons/Home.astro';
import Laptop from '@/components/icons/Laptop.astro';
import Layers from '@/components/icons/Layers.astro';
import type { Locale } from '@/config/i18n';
import { formatDateRange } from '@/lib/domain/dates';
import { pickLocale, pickLocaleArray } from '@/lib/domain/i18n';
import type { ModeKey, Role } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  role: Role;
  single: boolean;
}

const { locale, role, single } = Astro.props;

const modeIcons: Record<ModeKey, typeof Home> = {
  remote: Home,
  onsite: Building,
  hybrid: Laptop,
};
const ModeIcon = modeIcons[role.modeKey];

const title = pickLocale(role.title, locale);
const sector = pickLocale(role.sector, locale);
const mode = pickLocale(role.mode, locale);
const description = pickLocale(role.description, locale);
const bullets = pickLocaleArray(role.bullets, locale);
const dateRange = formatDateRange(role.startDate, role.endDate, locale);
---

<Glass as="article" interactive class={`role-card reveal ${single ? 'single-role' : ''}`}>
  {!single && <span class="role-node" aria-hidden="true" />}
  <div class="role-top">
    <div class="role-title">{title}</div>
    <div class="role-when mono">{dateRange}</div>
  </div>
  <div class="role-sub">
    <span><Layers size={13} /> {sector}</span>
    <span><ModeIcon size={13} /> {mode}</span>
  </div>
  <p class="role-desc">{description}</p>
  {
    bullets.length > 0 && (
      <ul class="role-list">
        {bullets.map((b) => (
          <li>{b}</li>
        ))}
      </ul>
    )
  }
  {
    role.technologies.length > 0 && (
      <div class="tags role-tags">
        {role.technologies.map((t) => (
          <Tag>{t.label}</Tag>
        ))}
      </div>
    )
  }
</Glass>

<style is:global>
  @layer utilities {
  .role-card {
    padding: clamp(20px, 3vw, 30px);
    position: relative;
  }
  .role-node {
    position: absolute;
    left: -29px;
    top: 28px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--bg), 0 0 14px oklch(0.7 0.18 var(--accent-h) / 0.7);
  }
  .role-top {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px 16px;
  }
  .role-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
  }
  .role-when {
    font-size: 0.78rem;
    color: var(--accent);
    white-space: nowrap;
  }
  .role-sub {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
    margin: 6px 0 0;
    font-size: 0.84rem;
    color: var(--text-faint);
  }
  .role-sub span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .role-desc {
    color: var(--text);
    margin: 16px 0 0;
    font-size: 1rem;
    text-wrap: pretty;
  }
  .role-list {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .role-list li {
    position: relative;
    padding-left: 24px;
    color: var(--text-soft);
    font-size: 0.95rem;
    text-wrap: pretty;
  }
  .role-list li::before {
    content: '';
    position: absolute;
    left: 4px;
    top: 9px;
    width: 7px;
    height: 7px;
    border-radius: 3px;
    background: var(--accent);
    transform: rotate(45deg);
    opacity: 0.85;
  }
  .role-tags {
    margin-top: 18px;
  }
  .single-role {
    padding-left: clamp(20px, 3vw, 30px);
  }
  .single-role .role-node {
    display: none;
  }
  @media (max-width: 460px) {
    .role-when {
      width: 100%;
    }
  }
  }
</style>
