---
import Glass from '@/components/Glass.astro';
import LocaleSwitch from '@/components/LocaleSwitch.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import ArrowUp from '@/components/icons/ArrowUp.astro';
import Code from '@/components/icons/Code.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';

interface Props {
  locale: Locale;
  shortName: string;
  avatarUrl: string | null;
}

const { locale, shortName, avatarUrl } = Astro.props;
const copy = COPY[locale];
const prefix = locale === 'es' ? '' : '/en';

const links = [
  { href: `${prefix}/#experience`, label: copy.nav.experience },
  { href: `${prefix}/#education`, label: copy.nav.education },
  { href: `${prefix}/#stack`, label: copy.nav.stack },
  { href: `${prefix}/#projects`, label: copy.nav.projects },
  { href: `${prefix}/#contact`, label: copy.nav.contact },
];
const homeHref = locale === 'es' ? '/' : '/en/';
---

<nav
  class="fixed top-4 left-0 right-0 mx-auto z-[100] w-[calc(100%-clamp(40px,8vw,64px))] max-w-[var(--maxw)]"
>
  <Glass
    class="flex items-center justify-between gap-3 px-3 py-2.5 pl-4 rounded-full"
  >
    <a
      href={`${homeHref}#top`}
      class="flex items-center gap-2.5 font-display font-bold tracking-[-0.02em] text-text no-underline"
    >
      {
        avatarUrl ? (
          <img
            src={avatarUrl}
            alt={shortName}
            width="30"
            height="30"
            loading="eager"
            class="w-[30px] h-[30px] rounded-full object-cover border border-glass-border"
          />
        ) : (
          <span
            class="w-[30px] h-[30px] rounded-full grid place-items-center bg-accent-soft text-accent font-bold"
            aria-hidden="true"
          >
            {shortName.charAt(0)}
          </span>
        )
      }
      <span>{shortName}</span>
    </a>
    <div class="nav-links flex items-center gap-1 max-[720px]:hidden">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-text-soft no-underline text-[0.9rem] font-medium px-3.5 py-2 rounded-full transition-[color,background] duration-[250ms] hover:text-text hover:bg-accent-soft aria-[current=true]:text-text aria-[current=true]:bg-accent-soft"
          >
            {link.label}
          </a>
        ))
      }
    </div>
    <div class="flex items-center gap-2">
      <LocaleSwitch current={locale} />
      <ThemeToggle locale={locale} />
      <button
        class="icon-btn nav-burger relative max-[720px]:grid! hidden"
        type="button"
        aria-label={copy.nav.openMenu}
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <Code
          class="nav-burger-icon nav-burger-open absolute transition-[opacity,transform] duration-200"
        />
        <ArrowUp
          class="nav-burger-icon nav-burger-close absolute transition-[opacity,transform] duration-200"
        />
      </button>
    </div>
  </Glass>
  <Glass
    id="nav-mobile"
    class="nav-mobile fixed top-[82px] left-[clamp(20px,4vw,32px)] right-[clamp(20px,4vw,32px)] z-[99] p-3 flex-col gap-1 origin-top transition-[opacity,transform] duration-[250ms] ease-out opacity-0 -translate-y-2 pointer-events-none hidden max-[720px]:flex data-[open=true]:opacity-100 data-[open=true]:translate-y-0 data-[open=true]:pointer-events-auto"
    data-open="false"
  >
    {
      links.map((link) => (
        <a
          class="text-text no-underline font-medium px-4 py-3 rounded-xl hover:bg-accent-soft hover:text-accent aria-[current=true]:bg-accent-soft aria-[current=true]:text-accent"
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
  </Glass>
</nav>

<style is:global>
  .nav-burger[aria-expanded='false'] .nav-burger-close,
  .nav-burger[aria-expanded='true'] .nav-burger-open {
    opacity: 0;
    transform: scale(0.6);
  }
</style>

<script>
  function bindBurger() {
    const burgers = document.querySelectorAll<HTMLButtonElement>('.nav-burger');
    for (const burger of burgers) {
      const menuId = burger.getAttribute('aria-controls');
      if (!menuId) continue;
      const menu = document.getElementById(menuId);
      if (!menu) continue;
      const openLabel = burger.getAttribute('aria-label') ?? '';
      const closeLabel = openLabel.replace(/^Abrir/, 'Cerrar').replace(/^Open/, 'Close');

      burger.addEventListener('click', () => {
        const expanded = burger.getAttribute('aria-expanded') === 'true';
        const next = !expanded;
        burger.setAttribute('aria-expanded', String(next));
        burger.setAttribute('aria-label', next ? closeLabel : openLabel);
        menu.setAttribute('data-open', String(next));
      });

      for (const link of menu.querySelectorAll('a')) {
        link.addEventListener('click', () => {
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', openLabel);
          menu.setAttribute('data-open', 'false');
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', openLabel);
          menu.setAttribute('data-open', 'false');
          burger.focus();
        }
      });
    }
  }

  bindBurger();
  document.addEventListener('astro:after-swap', bindBurger);
</script>
