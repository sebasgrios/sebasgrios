---
import Glass from '@/components/Glass.astro';
import LocaleSwitch from '@/components/LocaleSwitch.astro';
import ThemeToggle from '@/components/ThemeToggle.astro';
import ArrowUp from '@/components/icons/ArrowUp.astro';
import Code from '@/components/icons/Code.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';

interface Props {
  locale: Locale;
  shortName: string;
  avatarUrl: string | null;
}

const { locale, shortName, avatarUrl } = Astro.props;
const copy = COPY[locale];
const prefix = locale === 'es' ? '' : '/en';

const links = [
  { href: `${prefix}/#experience`, label: copy.nav.experience },
  { href: `${prefix}/#education`, label: copy.nav.education },
  { href: `${prefix}/#stack`, label: copy.nav.stack },
  { href: `${prefix}/#projects`, label: copy.nav.projects },
  { href: `${prefix}/#contact`, label: copy.nav.contact },
];
const homeHref = locale === 'es' ? '/' : '/en/';
---

<nav class="nav">
  <Glass class="nav-inner">
    <a href={`${homeHref}#top`} class="nav-brand">
      {
        avatarUrl ? (
          <img src={avatarUrl} alt={shortName} width="30" height="30" loading="eager" />
        ) : (
          <span class="nav-brand-fallback" aria-hidden="true">{shortName.charAt(0)}</span>
        )
      }
      <span>{shortName}</span>
    </a>
    <div class="nav-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
    <div class="nav-actions">
      <LocaleSwitch current={locale} />
      <ThemeToggle locale={locale} />
      <button
        class="icon-btn nav-burger"
        type="button"
        aria-label={copy.nav.openMenu}
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <Code class="nav-burger-icon nav-burger-open" />
        <ArrowUp class="nav-burger-icon nav-burger-close" />
      </button>
    </div>
  </Glass>
  <Glass id="nav-mobile" class="nav-mobile" hidden>
    {links.map((link) => <a class="nav-mobile-link" href={link.href}>{link.label}</a>)}
  </Glass>
</nav>

<style is:global>
  .nav {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    width: calc(100% - 32px);
    max-width: var(--maxw);
  }
  .nav .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px 10px 18px;
    border-radius: 999px;
    gap: 12px;
  }
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: inherit;
    text-decoration: none;
  }
  .nav-brand img {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--glass-border);
  }
  .nav-brand-fallback {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--accent-soft);
    color: var(--accent);
    font-weight: 700;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .nav-links a {
    color: var(--text-soft);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 999px;
    transition:
      color 0.25s,
      background 0.25s;
  }
  .nav-links a:hover {
    color: var(--text);
    background: var(--accent-soft);
  }
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .nav-burger {
    display: none;
  }
  .nav-burger-icon {
    position: absolute;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }
  .nav-burger[aria-expanded='false'] .nav-burger-close,
  .nav-burger[aria-expanded='true'] .nav-burger-open {
    opacity: 0;
    transform: scale(0.6);
  }
  .nav-mobile {
    position: fixed;
    top: 74px;
    left: 16px;
    right: 16px;
    z-index: 99;
    padding: 12px;
    display: none;
    flex-direction: column;
    gap: 4px;
    transform-origin: top;
  }
  @media (max-width: 720px) {
    .nav-mobile:not([hidden]) {
      display: flex;
    }
  }
  .nav-mobile-link {
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    padding: 12px 16px;
    border-radius: 12px;
  }
  .nav-mobile-link:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }
  @media (max-width: 720px) {
    .nav-links {
      display: none;
    }
    .nav-burger {
      display: grid;
    }
  }
</style>

<script>
  function bindBurger() {
    const burgers = document.querySelectorAll<HTMLButtonElement>('.nav-burger');
    for (const burger of burgers) {
      const menuId = burger.getAttribute('aria-controls');
      if (!menuId) continue;
      const menu = document.getElementById(menuId);
      if (!menu) continue;
      const openLabel = burger.getAttribute('aria-label') ?? '';
      const closeLabel = openLabel.replace(/^Abrir/, 'Cerrar').replace(/^Open/, 'Close');

      burger.addEventListener('click', () => {
        const expanded = burger.getAttribute('aria-expanded') === 'true';
        const next = !expanded;
        burger.setAttribute('aria-expanded', String(next));
        burger.setAttribute('aria-label', next ? closeLabel : openLabel);
        if (next) {
          menu.removeAttribute('hidden');
        } else {
          menu.setAttribute('hidden', '');
        }
      });

      for (const link of menu.querySelectorAll('a')) {
        link.addEventListener('click', () => {
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', openLabel);
          menu.setAttribute('hidden', '');
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
          burger.setAttribute('aria-expanded', 'false');
          burger.setAttribute('aria-label', openLabel);
          menu.setAttribute('hidden', '');
          burger.focus();
        }
      });
    }
  }

  bindBurger();
  document.addEventListener('astro:after-swap', bindBurger);
</script>
