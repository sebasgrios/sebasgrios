---
import Glass from '@/components/Glass.astro';
import SectionHead from '@/components/SectionHead.astro';
import Tag from '@/components/Tag.astro';
import GitHub from '@/components/icons/GitHub.astro';
import Play from '@/components/icons/Play.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { pickLocale } from '@/lib/domain/i18n';
import type { Project } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  projects: Project[];
}

const { locale, projects } = Astro.props;
const copy = COPY[locale].sections.projects;
const liveLabel = 'Live';
const codeLabel = 'Code';

const delays = ['', '[transition-delay:0.08s]', '[transition-delay:0.16s]'];
---

<section id="projects" aria-labelledby="projects-title" class="wrap">
  <SectionHead
    num="04"
    eyebrow={copy.eyebrow}
    title={copy.title}
    sub={copy.sub}
    id="projects-title"
  />
  <div class="grid grid-cols-2 gap-5 max-[940px]:grid-cols-1">
    {
      projects.map((project, index) => {
        const description = pickLocale(project.description, locale);
        const delayClass = delays[(index % 2) + 1];
        return (
          <Glass as="article" interactive class={`reveal ${delayClass} flex flex-col p-0 group`}>
            {project.liveUrl ? (
              <a
                class="relative aspect-[16/10] overflow-hidden border-b border-glass-border block"
                href={project.liveUrl}
                target="_blank"
                rel="noopener"
                aria-label={`${project.name} live site`}
              >
                {project.imageUrl && (
                  <img
                    src={project.imageUrl}
                    alt={`${project.name} screenshot`}
                    loading="lazy"
                    width="800"
                    height="500"
                    class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.06]"
                  />
                )}
                <div
                  class="absolute inset-0 bg-[linear-gradient(0deg,oklch(0.15_0.02_285/0.5),transparent_55%)] opacity-0 transition-opacity duration-400 group-hover:opacity-100"
                  aria-hidden="true"
                />
              </a>
            ) : (
              <div class="relative aspect-[16/10] overflow-hidden border-b border-glass-border block">
                {project.imageUrl && (
                  <img
                    src={project.imageUrl}
                    alt={`${project.name} screenshot`}
                    loading="lazy"
                    width="800"
                    height="500"
                    class="w-full h-full object-cover"
                  />
                )}
              </div>
            )}
            <div class="p-6 pt-[22px] flex flex-col gap-3 flex-1">
              <div class="flex items-center justify-between gap-2.5">
                <h3 class="font-display text-[1.35rem] font-bold tracking-[-0.02em] flex-1 min-w-0">
                  {project.name}
                </h3>
              </div>
              <p class="text-text-soft text-[0.96rem]">{description}</p>
              {project.technologies.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {project.technologies.map((t) => (
                    <Tag>{t.label}</Tag>
                  ))}
                </div>
              )}
              <div class="flex gap-2.5 mt-auto pt-1.5">
                {project.liveUrl && (
                  <a
                    class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold no-underline text-text px-4 py-2.5 rounded-full border border-border transition-all duration-300 hover:bg-accent hover:text-on-accent hover:border-accent hover:-translate-y-0.5"
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener"
                  >
                    <Play size={15} /> {liveLabel}
                  </a>
                )}
                {project.codeUrl && (
                  <a
                    class="inline-flex items-center gap-1.5 text-[0.85rem] font-semibold no-underline text-text px-4 py-2.5 rounded-full border border-border transition-all duration-300 hover:text-accent hover:border-accent hover:-translate-y-0.5"
                    href={project.codeUrl}
                    target="_blank"
                    rel="noopener"
                  >
                    <GitHub size={15} /> {codeLabel}
                  </a>
                )}
              </div>
            </div>
          </Glass>
        );
      })
    }
  </div>
</section>
