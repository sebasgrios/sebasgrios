---
import Glass from '@/components/Glass.astro';
import SectionHead from '@/components/SectionHead.astro';
import TechIcon from '@/components/TechIcon.astro';
import Pin from '@/components/icons/Pin.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { formatDateRange } from '@/lib/domain/dates';
import { pickLocale, pickLocaleArray } from '@/lib/domain/i18n';
import type { Education } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  education: Education[];
}

const { locale, education } = Astro.props;
const copy = COPY[locale].sections.education;
---

<section id="education" aria-labelledby="education-title" class="wrap">
  <SectionHead
    num="02"
    eyebrow={copy.eyebrow}
    title={copy.title}
    sub={copy.sub}
    id="education-title"
  />
  <div
    class="flex flex-col gap-4 relative pl-[30px] before:content-[''] before:absolute before:left-[5px] before:top-3.5 before:bottom-3.5 before:w-[2px] before:bg-[linear-gradient(var(--accent),transparent)] before:opacity-50 max-[720px]:pl-[22px]"
  >
    {
      education.map((e) => {
        const title = pickLocale(e.title, locale);
        const description = pickLocale(e.description, locale);
        const bullets = pickLocaleArray(e.bullets, locale);
        const dateRange = formatDateRange(e.startDate, e.endDate, locale);
        return (
          <Glass as="article" interactive class="reveal role-card-base">
            <span
              class="role-node absolute -left-[29px] top-7 w-3 h-3 rounded-full bg-accent shadow-[0_0_0_4px_var(--bg),0_0_14px_oklch(0.7_0.18_var(--accent-h)/0.7)] max-[720px]:-left-[22px]"
              aria-hidden="true"
            />
            <div class="flex flex-wrap items-baseline justify-between gap-y-2 gap-x-4">
              <div class="font-display font-bold text-[1.2rem]">{title}</div>
              <div class="font-mono text-[0.78rem] text-accent whitespace-nowrap max-[460px]:w-full">
                {dateRange}
              </div>
            </div>
            <div class="flex flex-wrap gap-y-2 gap-x-3.5 mt-1.5 text-[0.84rem] text-text-faint">
              <span class="inline-flex items-center gap-1.5">
                <Pin size={13} /> {e.school}
              </span>
            </div>
            <p class="text-text mt-4 text-base text-pretty">{description}</p>
            {bullets.length > 0 && (
              <ul class="role-bullet-list">
                {bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            )}
            {e.technologies.length > 0 && (
              <div class="flex flex-wrap gap-2.5 mt-[18px]">
                {e.technologies.map((t) => (
                  <TechIcon slug={t.key} label={t.label} />
                ))}
              </div>
            )}
          </Glass>
        );
      })
    }
  </div>
</section>
