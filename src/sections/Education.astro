---
import Glass from '@/components/Glass.astro';
import SectionHead from '@/components/SectionHead.astro';
import Tag from '@/components/Tag.astro';
import Pin from '@/components/icons/Pin.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { formatDateRange } from '@/lib/domain/dates';
import { pickLocale, pickLocaleArray } from '@/lib/domain/i18n';
import type { Education } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  education: Education[];
}

const { locale, education } = Astro.props;
const copy = COPY[locale].sections.education;
---

<section id="education" aria-labelledby="education-title" class="wrap">
  <SectionHead num="02" eyebrow={copy.eyebrow} title={copy.title} sub={copy.sub} id="education-title" />
  <div class="timeline">
    <div class="roles">
      {
        education.map((e) => {
          const title = pickLocale(e.title, locale);
          const description = pickLocale(e.description, locale);
          const bullets = pickLocaleArray(e.bullets, locale);
          const dateRange = formatDateRange(e.startDate, e.endDate, locale);
          return (
            <Glass as="article" interactive class="role-card reveal">
              <span class="role-node" aria-hidden="true" />
              <div class="role-top">
                <div class="role-title">{title}</div>
                <div class="role-when mono">{dateRange}</div>
              </div>
              <div class="role-sub">
                <span><Pin size={13} /> {e.school}</span>
              </div>
              <p class="role-desc">{description}</p>
              {bullets.length > 0 && (
                <ul class="role-list">
                  {bullets.map((b) => <li>{b}</li>)}
                </ul>
              )}
              {e.technologies.length > 0 && (
                <div class="tags role-tags">
                  {e.technologies.map((t) => <Tag>{t.label}</Tag>)}
                </div>
              )}
            </Glass>
          );
        })
      }
    </div>
  </div>
</section>
