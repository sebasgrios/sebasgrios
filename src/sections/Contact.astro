---
import Button from '@/components/Button.astro';
import Glass from '@/components/Glass.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedIn from '@/components/icons/LinkedIn.astro';
import Mail from '@/components/icons/Mail.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { pickLocale } from '@/lib/domain/i18n';
import type { Profile } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  profile: Profile;
}

const { locale, profile } = Astro.props;
const copy = COPY[locale].sections.contact;
const title = pickLocale(profile.contactTitle, locale);
const lead = pickLocale(profile.contactLead, locale);
const titleWords = title.split(' ');
const headTitle = titleWords.slice(0, -1).join(' ');
const tailTitle = titleWords.at(-1) ?? '';
---

<section id="contact" aria-labelledby="contact-title" class="contact wrap">
  <Glass class="contact-card reveal">
    <div class="eyebrow contact-eyebrow">
      <span class="sec-num">05</span>&nbsp;/&nbsp;{copy.eyebrow}
    </div>
    <h2 id="contact-title" class="contact-title">
      {headTitle}<br /><span class="big-accent">{tailTitle}</span>
    </h2>
    <p class="contact-lead">{lead}</p>
    <div class="contact-cta">
      <Button href={`mailto:${profile.email}`}>
        <Mail /> {profile.email}
      </Button>
      {
        profile.linkedinUrl && (
          <Button href={profile.linkedinUrl} variant="ghost" target="_blank" rel="noopener">
            <LinkedIn /> LinkedIn
          </Button>
        )
      }
      {
        profile.githubUrl && (
          <Button href={profile.githubUrl} variant="ghost" target="_blank" rel="noopener">
            <GitHub /> GitHub
          </Button>
        )
      }
    </div>
  </Glass>
</section>

<style is:global>
  @layer components {
  .contact {
    text-align: center;
  }
  .contact-card {
    padding: clamp(40px, 7vw, 80px) clamp(24px, 5vw, 64px);
    text-align: center;
    max-width: 820px;
    margin: 0 auto;
  }
  .contact-eyebrow {
    justify-content: center;
  }
  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin-top: 16px;
  }
  .contact .big-accent {
    background: linear-gradient(
      120deg,
      var(--accent-bright),
      oklch(0.72 0.18 calc(var(--accent-h) + 55))
    );
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .contact-lead {
    color: var(--text-soft);
    font-size: 1.1rem;
    margin: 18px auto 0;
    max-width: 50ch;
  }
  .contact-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
    margin-top: 34px;
  }
  }
</style>
