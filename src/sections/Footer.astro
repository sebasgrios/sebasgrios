---
import IconButton from '@/components/IconButton.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedIn from '@/components/icons/LinkedIn.astro';
import Mail from '@/components/icons/Mail.astro';
import type { Profile } from '@/lib/domain/types';

interface Props {
  profile: Profile;
}

const { profile } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="wrap mt-[clamp(48px,7vw,96px)] pt-10 pb-[60px] border-t border-hairline">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div class="text-text-faint text-[0.85rem]">© {year} {profile.fullName}</div>
    <div class="flex gap-2">
      {
        profile.githubUrl && (
          <IconButton href={profile.githubUrl} ariaLabel="GitHub" target="_blank" rel="noopener">
            <GitHub />
          </IconButton>
        )
      }
      {
        profile.linkedinUrl && (
          <IconButton
            href={profile.linkedinUrl}
            ariaLabel="LinkedIn"
            target="_blank"
            rel="noopener"
          >
            <LinkedIn />
          </IconButton>
        )
      }
      <IconButton href={`mailto:${profile.email}`} ariaLabel="Email">
        <Mail />
      </IconButton>
    </div>
  </div>
</footer>
