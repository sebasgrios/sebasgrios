---
import Glass from '@/components/Glass.astro';
import RoleCard from '@/components/RoleCard.astro';
import SectionHead from '@/components/SectionHead.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { pickLocale } from '@/lib/domain/i18n';
import type { Company } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  companies: Company[];
}

const { locale, companies } = Astro.props;
const copy = COPY[locale].sections.experience;
---

<section id="experience" aria-labelledby="experience-title" class="wrap">
  <SectionHead num="01" eyebrow={copy.eyebrow} title={copy.title} sub={copy.sub} id="experience-title" />
  <div class="timeline">
    {
      companies.map((company) => {
        const single = company.roles.length === 1;
        const metaLine = pickLocale(company.metaLine, locale);
        return (
          <div class="tl-company reveal">
            <div class="company-head">
              <Glass class="company-logo">
                {company.logoUrl && (
                  <img src={company.logoUrl} alt={company.name} width="46" height="46" loading="lazy" />
                )}
              </Glass>
              <div>
                <div class="cname">{company.name}</div>
                <div class="cmeta mono">{metaLine}</div>
              </div>
            </div>
            <div class={single ? '' : 'roles'}>
              {company.roles.map((role) => (
                <RoleCard locale={locale} role={role} single={single} />
              ))}
            </div>
          </div>
        );
      })
    }
  </div>
</section>

<style is:global>
  @layer components {
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .tl-company {
    position: relative;
    padding-left: 0;
  }
  .company-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 8px 0 16px;
  }
  .company-logo {
    width: 46px;
    height: 46px;
    border-radius: 13px;
    flex-shrink: 0;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
  }
  .company-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .company-head .cname {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
  }
  .company-head .cmeta {
    font-size: 0.85rem;
    color: var(--text-faint);
  }
  .roles {
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: relative;
    padding-left: 30px;
  }
  .roles::before {
    content: '';
    position: absolute;
    left: 5px;
    top: 14px;
    bottom: 14px;
    width: 2px;
    background: linear-gradient(var(--accent), transparent);
    opacity: 0.5;
  }
  @media (max-width: 720px) {
    .roles {
      padding-left: 22px;
    }
    .role-node {
      left: -22px;
    }
  }
  }
</style>
