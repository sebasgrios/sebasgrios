---
import { Image } from 'astro:assets';
import Button from '@/components/Button.astro';
import Glass from '@/components/Glass.astro';
import Arrow from '@/components/icons/Arrow.astro';
import GitHub from '@/components/icons/GitHub.astro';
import LinkedIn from '@/components/icons/LinkedIn.astro';
import { COPY } from '@/config/copy';
import type { Locale } from '@/config/i18n';
import { pickLocale, pickLocaleArray } from '@/lib/domain/i18n';
import type { Profile } from '@/lib/domain/types';

interface Props {
  locale: Locale;
  profile: Profile;
  stats: {
    yearsOfExperience: number;
    sectorsCount: number;
    projectsCount: number;
  };
}

const { locale, profile, stats } = Astro.props;
const copy = COPY[locale];
const role = pickLocale(profile.role, locale);
const lead = pickLocale(profile.lead, locale);
const status = pickLocale(profile.statusLabel, locale);
const floatBadges = pickLocaleArray(profile.heroBadges, locale);
const nameParts = profile.fullName.split(' ');
const firstName = nameParts[0] ?? profile.fullName;
const lastName = nameParts.slice(1).join(' ');
const sectorsLabel = `${stats.sectorsCount} ${copy.hero.statSectors}`;
---

<header
  id="top"
  class="wrap pt-[clamp(116px,16vh,188px)] max-[940px]:pt-[clamp(92px,13vh,116px)]"
>
  <div
    class="grid items-start gap-x-[clamp(28px,4vw,56px)] grid-cols-[1.25fr_0.85fr] grid-rows-[auto_1fr] [grid-template-areas:'badge_photo''main_photo'] max-[940px]:grid-cols-[1fr] max-[940px]:grid-rows-[auto_auto_auto] max-[940px]:[grid-template-areas:'badge''photo''main'] max-[940px]:gap-x-0"
  >
    <Glass
      class="reveal [grid-area:badge] justify-self-start self-start inline-flex items-center gap-2.5 mb-[26px] px-[15px] py-[7px] rounded-full text-[0.85rem] font-medium"
    >
      <span
        class="w-[7px] h-[7px] rounded-full bg-[oklch(0.72_0.2_150)] data-[active=true]:animate-[status-pulse_2.4s_infinite]"
        data-active={profile.isOpenToWork}
        aria-hidden="true"></span>
      {status}
    </Glass>
    <div
      class="reveal [transition-delay:0.16s] [grid-area:photo] self-center relative max-[940px]:max-w-[min(380px,calc(50%+150px))] max-[940px]:mx-auto max-[940px]:mt-1 max-[940px]:mb-[26px]"
    >
      <div class="relative will-change-transform" data-parallax>
        <Glass
          interactive
          class="p-2.5 rounded-[28px] [-webkit-backdrop-filter:none] [backdrop-filter:none] bg-glass-bg"
        >
          {
            profile.photoUrl && (
              <Image
                src={profile.photoUrl}
                alt={profile.fullName}
                width={480}
                height={600}
                densities={[1, 2]}
                format="webp"
                quality={72}
                loading="eager"
                fetchpriority="high"
                class="w-full aspect-[4/5] object-cover rounded-[20px] block"
              />
            )
          }
        </Glass>
        {
          floatBadges[0] && (
            <div
              class="absolute z-[2] px-4 py-2.5 rounded-[14px] text-[0.82rem] font-semibold flex items-center gap-2 max-w-[calc(100%-16px)] whitespace-nowrap border border-glass-border bg-[color-mix(in_oklab,var(--bg-2)_85%,transparent)] bottom-[22px] -left-[16px] max-[940px]:left-3 max-[940px]:bottom-[18px] max-[720px]:left-2"
            >
              <span class="w-2 h-2 rounded-full bg-accent" aria-hidden="true" />
              {floatBadges[0]}
            </div>
          )
        }
        {
          floatBadges[1] && (
            <div
              class="absolute z-[2] px-4 py-2.5 rounded-[14px] text-[0.82rem] font-semibold flex items-center gap-2 max-w-[calc(100%-16px)] whitespace-nowrap border border-glass-border bg-[color-mix(in_oklab,var(--bg-2)_85%,transparent)] top-[26px] -right-[16px] max-[940px]:right-3 max-[940px]:top-[18px] max-[720px]:right-2"
            >
              <span class="w-2 h-2 rounded-full bg-accent" aria-hidden="true" />
              {floatBadges[1]}
            </div>
          )
        }
      </div>
    </div>
    <div class="[grid-area:main] self-start min-w-0">
      <h1
        class="reveal [transition-delay:0.08s] font-display text-[clamp(2.6rem,7vw,5rem)] font-black tracking-[-0.02em] leading-[1.05]"
      >
        {firstName}<br />{lastName}
      </h1>
      <p
        class="reveal [transition-delay:0.16s] mt-3.5 font-display font-semibold text-[clamp(1.1rem,2.4vw,1.5rem)] text-text-soft tracking-[-0.01em]"
      >
        {role}
      </p>
      <p
        class="reveal [transition-delay:0.16s] mt-[22px] max-w-[48ch] text-text-soft text-[1.1rem] text-pretty"
      >
        {lead}
      </p>
      <div
        class="reveal [transition-delay:0.24s] flex flex-wrap gap-3 mt-8 max-[720px]:gap-2.5 max-[720px]:[&_.btn]:justify-center max-[720px]:[&_.btn-ghost]:flex-1 max-[720px]:[&_.btn-ghost]:basis-0 max-[720px]:[&_.btn-ghost]:min-w-0 max-[720px]:[&_.btn-ghost]:order-1 max-[720px]:[&_.btn-primary]:basis-full max-[720px]:[&_.btn-primary]:order-2"
      >
        <Button href="#contact">
          {copy.hero.cta} <Arrow />
        </Button>
        {
          profile.githubUrl && (
            <Button href={profile.githubUrl} variant="ghost" target="_blank" rel="noopener">
              <GitHub /> GitHub
            </Button>
          )
        }
        {
          profile.linkedinUrl && (
            <Button href={profile.linkedinUrl} variant="ghost" target="_blank" rel="noopener">
              <LinkedIn /> LinkedIn
            </Button>
          )
        }
      </div>
      <div
        class="reveal [transition-delay:0.24s] flex flex-wrap gap-3.5 mt-10 max-[720px]:[&>.stat]:flex-1 max-[720px]:[&>.stat]:basis-[140px] max-[720px]:[&>.stat]:min-w-0 max-[460px]:gap-2.5"
      >
        <Glass class="stat px-5 py-4 rounded-[var(--radius-glass-sm)] min-w-[120px] flex-1 basis-[140px]">
          <div
            class="font-display font-black text-[clamp(1.8rem,4vw,2.6rem)] leading-none tracking-[-0.03em] bg-[linear-gradient(120deg,var(--accent-bright),oklch(0.7_0.18_calc(var(--accent-h)+55)))] bg-clip-text text-transparent"
          >
            +{stats.yearsOfExperience} {locale === 'es' ? 'años' : 'years'}
          </div>
          <div class="text-[0.8rem] text-text-soft mt-1.5">{copy.hero.statYears}</div>
        </Glass>
        <Glass class="stat px-5 py-4 rounded-[var(--radius-glass-sm)] min-w-[120px] flex-1 basis-[140px]">
          <div
            class="font-display font-black text-[clamp(1.8rem,4vw,2.6rem)] leading-none tracking-[-0.03em] bg-[linear-gradient(120deg,var(--accent-bright),oklch(0.7_0.18_calc(var(--accent-h)+55)))] bg-clip-text text-transparent"
          >
            {stats.sectorsCount}
          </div>
          <div class="text-[0.8rem] text-text-soft mt-1.5">{sectorsLabel}</div>
        </Glass>
        <Glass class="stat px-5 py-4 rounded-[var(--radius-glass-sm)] min-w-[120px] flex-1 basis-[140px]">
          <div
            class="font-display font-black text-[clamp(1.8rem,4vw,2.6rem)] leading-none tracking-[-0.03em] bg-[linear-gradient(120deg,var(--accent-bright),oklch(0.7_0.18_calc(var(--accent-h)+55)))] bg-clip-text text-transparent"
          >
            {stats.projectsCount}
          </div>
          <div class="text-[0.8rem] text-text-soft mt-1.5">{copy.hero.statProjects}</div>
        </Glass>
      </div>
    </div>
  </div>
</header>
