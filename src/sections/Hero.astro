---
import { Image } from 'astro:assets';

import { SITE } from '@/data/site';
import SebasGRios from '@/images/sebasgrios.webp';
import Tooltip from '@/components/Tooltip.astro';
import DiscountIcon from '@/components/icons/Discount.astro';
import GithubIcon from '@/components/icons/Github.astro';
import LinkedinIcon from '@/components/icons/Linkedin.astro';
import { getYearsOfExperience } from '@/utils/date';

const initialYears = getYearsOfExperience(SITE.experienceStartDate);
---

<section class='flex flex-col md:flex-row gap-4 items-center justify-start'>
  <div class='relative' data-header-avatar-trigger>
    <Image
      alt='Foto de Sebastián'
      class='bg-clip-padding rounded-full border-8 border-white shadow-lg size-48 dark:border-[#121212]'
      src={SebasGRios}
    />
    <a
      aria-label='Enviar correo a Sebastián González Ríos'
      class='absolute bottom-3 group right-3'
      href='mailto:contact@sebasgrios.es'
      rel='noopener noreferrer'
      target='_blank'
    >
      <Tooltip description='Abierto a propuestas'>
        <DiscountIcon
          class='duration-200 rounded-full shadow-md size-10 stroke-cyan-500 fill-white/50 group-hover:fill-white dark:fill-[var(--dark-surface)] group-hover:dark:fill-[var(--dark-surface-strong)]'
        />
      </Tooltip>
    </a>
  </div>
  <div class='flex flex-col gap-4 items-center md:items-start justify-center'>
    <div class='flex flex-col gap-2 items-start justify-center'>
      <h1 class='font-bold text-2xl md:text-4xl text-gray-800 dark:text-[var(--dark-text)]'>
        Sebastián González Ríos
      </h1>
      <p class='font-medium text-sm md:text-xl text-gray-600 dark:text-[var(--dark-text-muted)]'>
        <span class='text-yellow-500' data-years-experience>+{initialYears} años de experiencia</span> en {SITE.jobTitle}.
      </p>
    </div>
    <div class='flex flex-row gap-2 items-center justify-center'>
      <a
        class='bg-[#0e76a8] hover:bg-[#258dbf] dark:hover:bg-[#0a92d1] cursor-pointer font-medium flex flex-row gap-2 items-center p-2 rounded-xl shadow-md text-white'
        href='https://linkedin.com/in/sebasgrios/'
        rel='noopener noreferrer'
        target='_blank'
      >
        <LinkedinIcon class='size-6 fill-white' /> Linkedin
      </a>
      <a
        class='bg-[#171515] hover:bg-[#2b2a2a] dark:bg-white dark:hover:bg-neutral-200 cursor-pointer font-medium flex flex-row gap-2 items-center p-2 rounded-xl shadow-md text-white dark:text-black'
        href='https://github.com/sebasgrios'
        rel='noopener noreferrer'
        target='_blank'
      >
        <GithubIcon class='size-6 fill-white dark:fill-black' /> Github
      </a>
    </div>
  </div>
</section>

<script define:vars={{ initialYears, startMonth: SITE.experienceStartDate.month, startYear: SITE.experienceStartDate.year }} is:inline>
  const updateExperienceYears = () => {
    const currentDate = new Date();
    let experienceYears = currentDate.getFullYear() - startYear;
    const monthDiff = currentDate.getMonth() - (startMonth - 1);

    if (monthDiff < 0) {
      experienceYears -= 1;
    }

    if (experienceYears === initialYears) {
      return;
    }

    const yearsElement = document.querySelector('[data-years-experience]');

    if (yearsElement instanceof HTMLElement) {
      yearsElement.textContent = `+${experienceYears} años de experiencia`;
    }
  };

  updateExperienceYears();
</script>
