---
import '@fontsource-variable/libre-franklin';
import { ViewTransitions } from 'astro:transitions';

import { SITE } from '@/data/site';
import Header from '@/components/Header.astro';

interface Props {
	description?: string;
	title: string;
}

const { description = SITE.description, title } = Astro.props;
---

<!doctype html>
<html lang={SITE.language}>
	<head>
		<meta charset='UTF-8' />
		<meta name='author' content={SITE.author} />
		<meta name='description' content={description} />
		<meta name='viewport' content='width=device-width' />
		<link rel='icon' type='image/svg+xml' href='/favicon.svg' />
		<meta name='generator' content={Astro.generator} />
		<title>{title}</title>
		<ViewTransitions />
		<script is:inline>
			const theme = localStorage.theme === 'dark'
				? 'dark'
				: localStorage.theme === 'light'
					? 'light'
					: window.matchMedia('(prefers-color-scheme: dark)').matches
						? 'dark'
						: 'light';

			document.documentElement.classList.toggle('dark', theme === 'dark');
		</script>
	</head>
	<body class='min-h-screen bg-gray-100 text-gray-950 dark:bg-[#0a0a0a] dark:text-gray-50'>
		<Header />
		<slot />
	</body>
</html>

<style is:global>
	:root {
		--dark-bg: #0a0a0a;
		--dark-surface: rgba(28, 28, 30, 0.88);
		--dark-surface-strong: #161616;
		--dark-surface-soft: rgba(38, 38, 40, 0.82);
		--dark-border: rgba(255, 255, 255, 0.09);
		--dark-text: #f5f5f5;
		--dark-text-muted: #a3a3a3;
	}

	html {
		font-family: 'Libre Franklin Variable', system-ui, sans-serif;
		scroll-behavior: smooth;
	}

	body {
		background-image: radial-gradient(circle at top, rgba(255, 255, 255, 0.45), transparent 32rem);
	}

	.dark body {
		background-image:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.035), transparent 26rem),
			linear-gradient(to bottom, rgba(255, 255, 255, 0.015), transparent 18rem);
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}
	}
</style>
