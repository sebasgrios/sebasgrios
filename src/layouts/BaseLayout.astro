---
import BgField from '@/components/BgField.astro';
import BgNoise from '@/components/BgNoise.astro';
import { CLOUDFLARE_WEB_ANALYTICS } from '@/config/analytics';
import type { Locale } from '@/config/i18n';
import { SITE } from '@/config/site';
import '@/styles/globals.css';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonical?: string;
  ogImage?: string;
  personName?: string;
  personRole?: string;
}

const {
  title,
  description,
  locale,
  canonical,
  ogImage,
  personName,
  personRole,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString();
const alternateEs = new URL(Astro.url.pathname.replace(/^\/en\//, '/'), SITE.url).toString();
const alternateEn = new URL(
  Astro.url.pathname.startsWith('/en/') ? Astro.url.pathname : `/en${Astro.url.pathname}`,
  SITE.url
).toString();
const ogImageUrl = ogImage ?? new URL(`/og/${locale}.png`, SITE.url).toString();

const beaconToken = CLOUDFLARE_WEB_ANALYTICS.beaconToken;
const showAnalytics = import.meta.env.PROD && !!beaconToken;

const person = personName
  ? {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: personName,
      jobTitle: personRole,
      email: SITE.defaultEmail,
      url: SITE.url,
      image: ogImageUrl,
      sameAs: [SITE.defaultLinkedin, SITE.defaultGithub],
    }
  : null;

const personJson = person ? JSON.stringify(person).replace(/</g, '\\u003c') : null;
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="es" href={alternateEs} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="x-default" href={alternateEs} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={locale === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={locale === 'es' ? 'en_US' : 'es_ES'} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    {
      personJson && (
        <script is:inline type="application/ld+json" set:html={personJson} />
      )
    }
    <link rel="preconnect" href="https://nzbodijggjxhshqqpnue.supabase.co" crossorigin />
    <link rel="dns-prefetch" href="https://nzbodijggjxhshqqpnue.supabase.co" />
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('sgr-theme');
          var dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          document.documentElement.dataset.theme = s || (dark ? 'dark' : 'light');
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    {
      showAnalytics && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token":"${beaconToken}"}`}
        />
      )
    }
  </head>
  <body>
    <BgField />
    <BgNoise />
    <a href="#main" class="sr-only">Skip to main content</a>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <script>
      import '@/scripts/effects.client.ts';
    </script>
  </body>
</html>
