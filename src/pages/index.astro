---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { COPY } from '@/config/copy';
import { loadHomeData } from '@/lib/data/loaders';
import { pickLocale } from '@/lib/domain/i18n';

export const prerender = true;

const locale = 'es' as const;
const copy = COPY[locale];
const data = await loadHomeData();
const { profile, stats } = data;
const role = pickLocale(profile.role, locale);
const lead = pickLocale(profile.lead, locale);
const metaTitle = pickLocale(profile.metaTitle, locale);
const metaDescription = pickLocale(profile.metaDescription, locale);
---

<BaseLayout title={metaTitle} description={metaDescription} locale={locale}>
  <section class="wrap" style="padding-block: clamp(80px, 14vh, 160px);">
    <p class="font-mono text-sm uppercase tracking-[0.22em] text-[var(--text-faint)]">
      M4 · datos desde supabase
    </p>
    <h1 class="font-[var(--font-display)] text-5xl mt-3" style="letter-spacing: -0.02em;">
      {profile.fullName}
    </h1>
    <p class="mt-3 text-[var(--text-soft)]">{role}</p>
    <p class="mt-4 max-w-prose text-[var(--text-soft)]">{lead}</p>
    <div class="mt-8 flex gap-6 flex-wrap text-sm text-[var(--text-faint)]">
      <span><strong>+{stats.yearsOfExperience}</strong> {copy.hero.statYears}</span>
      <span><strong>{stats.sectorsCount}</strong> {copy.hero.statSectors}</span>
      <span><strong>{stats.projectsCount}</strong> {copy.hero.statProjects}</span>
    </div>
    <p class="mt-8 text-xs text-[var(--text-faint)]">
      Locale: {locale} · Roles cargados:
      {data.companies.reduce((acc, c) => acc + c.roles.length, 0)} · Education:
      {data.education.length} · Stack groups: {data.stackGroups.length} · Projects:
      {data.projects.length}
    </p>
  </section>
</BaseLayout>
