---
import Button from '@/components/Button.astro';
import Glass from '@/components/Glass.astro';
import Arrow from '@/components/icons/Arrow.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const { user } = Astro.locals;

const sections = [
  { label: 'Perfil', hint: 'Datos del hero, contacto y SEO.', href: '/admin/profile' },
  { label: 'Empresas y roles', hint: 'Experiencia y posiciones.', href: '/admin/companies' },
  { label: 'Formación', hint: 'Ciclos y estudios.', href: '/admin/education' },
  { label: 'Stack', hint: 'Grupos de tecnologías.', href: '/admin/stack' },
  { label: 'Tecnologías', hint: 'Taxonomía reutilizable.', href: '/admin/technologies' },
  { label: 'Proyectos', hint: 'Trabajo propio.', href: '/admin/projects' },
  { label: 'Medios', hint: 'Imágenes en Storage.', href: null },
  { label: 'Publicar', hint: 'Disparar redeploy.', href: null },
];

const revealDelays = ['', '[transition-delay:0.05s]', '[transition-delay:0.1s]', '[transition-delay:0.15s]'];
---

<BaseLayout title="Panel · Backoffice" description="Backoffice." locale="es" noindex>
  <section class="wrap py-[clamp(72px,11vh,130px)]">
    <div class="flex items-center justify-between gap-4 flex-wrap mb-10 max-w-[640px] mx-auto">
      <div>
        <p class="font-mono text-[0.72rem] uppercase tracking-[0.22em] text-text-faint">
          Backoffice
        </p>
        <h1
          class="font-display text-[clamp(1.8rem,4vw,2.6rem)] font-black tracking-[-0.02em] mt-1"
        >
          Panel
        </h1>
      </div>
      <div class="flex items-center gap-3">
        {user?.email && <span class="text-text-soft text-[0.9rem]">{user.email}</span>}
        <form method="post" action="/api/auth/signout">
          <Button variant="ghost" type="submit">Salir</Button>
        </form>
      </div>
    </div>

    <div class="flex flex-col gap-3 max-w-[640px] mx-auto">
      {
        sections.map((section, index) => {
          const delay = revealDelays[index % revealDelays.length];
          const card = (
            <Glass
              interactive={Boolean(section.href)}
              class={`reveal ${delay} flex items-center justify-between gap-4 px-5 py-4`}
            >
              <div class="min-w-0">
                <div class="font-display font-bold text-[1.05rem]">{section.label}</div>
                <div class="text-text-faint text-[0.85rem] mt-0.5">{section.hint}</div>
              </div>
              {section.href ? (
                <Arrow class="shrink-0 text-text-soft" />
              ) : (
                <span class="shrink-0 font-mono text-[0.6rem] uppercase tracking-[0.16em] text-text-faint border border-hairline rounded-full px-2 py-0.5">
                  pendiente
                </span>
              )}
            </Glass>
          );
          return section.href ? (
            <a href={section.href} class="no-underline block">
              {card}
            </a>
          ) : (
            card
          );
        })
      }
    </div>
  </section>
</BaseLayout>
