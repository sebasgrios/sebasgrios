---
import AdminAccordion from '@/components/admin/AdminAccordion.astro';
import AdminField from '@/components/admin/AdminField.astro';
import Button from '@/components/Button.astro';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { createSupabaseServerClient } from '@/lib/auth/supabaseServer';
import { MEDIA_BUCKETS, listBucket } from '@/lib/data/storage';

export const prerender = false;

const client = createSupabaseServerClient(Astro);
const buckets = await Promise.all(
  MEDIA_BUCKETS.map(async (bucket) => ({ bucket, files: await listBucket(client, bucket) }))
);
const danger = 'text-[oklch(0.62_0.22_25)] text-[0.9rem] font-medium cursor-pointer';
const fileInput =
  'w-full text-[0.85rem] text-text-soft file:mr-3 file:rounded-full file:border-0 file:bg-accent-soft file:text-accent file:px-3 file:py-1.5 file:text-[0.8rem] file:font-medium file:cursor-pointer';
---

<AdminLayout title="Medios">
  <div class="flex flex-col gap-3">
    {
      buckets.map(({ bucket, files }) => (
        <AdminAccordion title={`${bucket} · ${files.length}`} id={bucket}>
          <form
            method="post"
            action="/api/media"
            enctype="multipart/form-data"
            class="flex flex-col gap-3"
          >
            <input type="hidden" name="bucket" value={bucket} />
            <input type="hidden" name="_action" value="upload" />
            <input type="file" name="file" required class={fileInput} />
            <AdminField label="Nombre (opcional)" name="filename" placeholder="usa el del archivo" />
            <div class="flex justify-end">
              <Button type="submit">Subir</Button>
            </div>
          </form>

          {files.length > 0 && (
            <div class="flex flex-col gap-2.5 border-t border-hairline pt-3">
              {files.map((file) => (
                <div class="flex items-center gap-3">
                  <img
                    src={file.url}
                    alt={file.name}
                    width="40"
                    height="40"
                    loading="lazy"
                    class="size-10 rounded-lg object-cover border border-hairline shrink-0 bg-bg-2"
                  />
                  <div class="min-w-0 flex-1">
                    <div class="text-[0.85rem] truncate">{file.name}</div>
                    <input
                      readonly
                      value={file.url}
                      class="w-full text-[0.7rem] text-text-faint bg-transparent outline-none truncate"
                    />
                  </div>
                  <form method="post" action="/api/media" data-confirm={`¿Eliminar ${file.name}?`}>
                    <input type="hidden" name="bucket" value={bucket} />
                    <input type="hidden" name="_action" value="delete" />
                    <input type="hidden" name="path" value={file.name} />
                    <button type="submit" class={danger} aria-label={`Eliminar ${file.name}`}>
                      ✕
                    </button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </AdminAccordion>
      ))
    }
  </div>
</AdminLayout>
