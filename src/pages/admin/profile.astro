---
import AdminAccordion from '@/components/admin/AdminAccordion.astro';
import AdminField from '@/components/admin/AdminField.astro';
import AdminLocalized from '@/components/admin/AdminLocalized.astro';
import Button from '@/components/Button.astro';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { fetchProfile } from '@/lib/data/repos';

export const prerender = false;

const profile = await fetchProfile();
const badgeRows = [0, 1, 2, 3].map((index) => profile.heroBadges[index] ?? { es: '', en: '' });
---

<AdminLayout title="Perfil">
  <form method="post" action="/api/profile" class="flex flex-col gap-3">
    <AdminAccordion title="Identidad" id="identity">
      <div class="grid gap-3 sm:grid-cols-2">
        <AdminField label="Nombre completo" name="fullName" value={profile.fullName} required />
        <AdminField label="Nombre corto (nav)" name="shortName" value={profile.shortName} required />
      </div>
      <AdminLocalized label="Rol" name="role" es={profile.role.es} en={profile.role.en} />
    </AdminAccordion>

    <AdminAccordion title="Hero" id="hero">
      <AdminLocalized label="Lead" name="lead" es={profile.lead.es} en={profile.lead.en} multiline />
      <AdminLocalized
        label="Etiqueta de estado"
        name="statusLabel"
        es={profile.statusLabel.es}
        en={profile.statusLabel.en}
      />
      <label class="flex items-center gap-2.5 text-[0.9rem]">
        <input
          type="checkbox"
          name="isOpenToWork"
          checked={profile.isOpenToWork}
          class="size-4 rounded accent-[var(--accent)]"
        />
        Abierto a propuestas (punto verde animado)
      </label>
      <AdminField
        label="Inicio de experiencia"
        name="experienceStartDate"
        type="date"
        value={profile.experienceStartDate}
        required
      />
      <div class="flex flex-col gap-3">
        <span class="text-[0.8rem] font-medium text-text-soft">Badges flotantes (opcionales)</span>
        {
          badgeRows.map((badge, index) => (
            <AdminLocalized
              label={`Badge ${index + 1}`}
              name={`heroBadges.${index}`}
              es={badge.es}
              en={badge.en}
              required={false}
            />
          ))
        }
      </div>
    </AdminAccordion>

    <AdminAccordion title="Imágenes y enlaces" id="links">
      <div class="grid gap-3 sm:grid-cols-2">
        <AdminField label="URL avatar" name="avatarUrl" type="url" value={profile.avatarUrl} />
        <AdminField label="URL foto hero" name="photoUrl" type="url" value={profile.photoUrl} />
        <AdminField label="Email" name="email" type="email" value={profile.email} required />
        <AdminField label="LinkedIn" name="linkedinUrl" type="url" value={profile.linkedinUrl} />
        <AdminField label="GitHub" name="githubUrl" type="url" value={profile.githubUrl} />
      </div>
    </AdminAccordion>

    <AdminAccordion title="Contacto" id="contact">
      <AdminLocalized
        label="Título"
        name="contactTitle"
        es={profile.contactTitle.es}
        en={profile.contactTitle.en}
      />
      <AdminLocalized
        label="Lead"
        name="contactLead"
        es={profile.contactLead.es}
        en={profile.contactLead.en}
        multiline
      />
    </AdminAccordion>

    <AdminAccordion title="SEO" id="seo">
      <AdminLocalized
        label="Meta title"
        name="metaTitle"
        es={profile.metaTitle.es}
        en={profile.metaTitle.en}
      />
      <AdminLocalized
        label="Meta description"
        name="metaDescription"
        es={profile.metaDescription.es}
        en={profile.metaDescription.en}
        multiline
      />
    </AdminAccordion>

    <div class="flex justify-end mt-3">
      <Button type="submit">Guardar cambios</Button>
    </div>
  </form>
</AdminLayout>
