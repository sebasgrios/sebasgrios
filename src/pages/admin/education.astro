---
import AdminAccordion from '@/components/admin/AdminAccordion.astro';
import DeleteForm from '@/components/admin/DeleteForm.astro';
import EducationFields from '@/components/admin/EducationFields.astro';
import Button from '@/components/Button.astro';
import AdminLayout from '@/layouts/AdminLayout.astro';
import { fetchEducationAdmin, fetchTechnologiesAdmin } from '@/lib/data/repos';

export const prerender = false;

const [entries, technologies] = await Promise.all([
  fetchEducationAdmin(),
  fetchTechnologiesAdmin(),
]);
const nextSort = entries.reduce((max, entry) => Math.max(max, entry.sortOrder), -1) + 1;
---

<AdminLayout title="Formación">
  <div class="flex flex-col gap-3">
    <AdminAccordion title="Nueva formación" id="new">
      <form method="post" action="/api/education" class="flex flex-col gap-4">
        <input type="hidden" name="_action" value="create" />
        <EducationFields education={null} technologies={technologies} nextSort={nextSort} />
        <div class="flex justify-end">
          <Button type="submit">Añadir</Button>
        </div>
      </form>
    </AdminAccordion>

    {
      entries.map((entry) => (
        <AdminAccordion title={entry.title.es || entry.title.en} id={entry.id}>
          <form method="post" action="/api/education" class="flex flex-col gap-4">
            <input type="hidden" name="_action" value="update" />
            <input type="hidden" name="id" value={entry.id} />
            <EducationFields education={entry} technologies={technologies} nextSort={nextSort} />
            <div class="flex justify-end">
              <Button type="submit">Guardar</Button>
            </div>
          </form>
          <DeleteForm
            action="/api/education"
            confirm={`¿Eliminar "${entry.title.es || entry.title.en}"?`}
            fields={{ id: entry.id }}
          />
        </AdminAccordion>
      ))
    }
  </div>
</AdminLayout>
