---
import Button from '@/components/Button.astro';
import Glass from '@/components/Glass.astro';
import Arrow from '@/components/icons/Arrow.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Acceso · Backoffice"
  description="Área privada del backoffice."
  locale="es"
  noindex
>
  <section class="wrap min-h-[78vh] grid place-items-center py-[clamp(80px,12vh,140px)]">
    <Glass class="p-[clamp(28px,5vw,48px)] max-w-[420px] w-full text-center">
      <p class="font-mono text-[0.72rem] uppercase tracking-[0.22em] text-text-faint">
        Backoffice
      </p>
      <h1
        class="font-display text-[clamp(1.8rem,4vw,2.4rem)] font-black tracking-[-0.02em] mt-3"
      >
        Acceso privado
      </h1>
      <p class="text-text-soft mt-3">
        Inicia sesión con tu cuenta de Google autorizada.
      </p>
      {
        error && (
          <p class="text-[oklch(0.62_0.2_25)] text-[0.9rem] mt-4" role="alert">
            No se pudo iniciar sesión ({error}).
          </p>
        )
      }
      <div class="mt-7 flex justify-center">
        <Button href="/api/auth/signin">
          Entrar con Google <Arrow />
        </Button>
      </div>
    </Glass>
  </section>
</BaseLayout>
