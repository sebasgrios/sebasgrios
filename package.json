{
  "name": "portfolio",
  "description": "Portfolio de Sebastián González Ríos",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Sebastián González Ríos",
    "email": "contact@sebasgrios.es",
    "url": "https://www.sebasgrios.es"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check && biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:types": "supabase gen types typescript --linked > src/lib/data/database.types.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-wasm": "^2.6.2",
    "@supabase/supabase-js": "^2.107.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.4.16",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "sharp": "^0.34.5",
