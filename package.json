{
  "name": "portfolio",
  "description": "Portfolio de Sebastián González Ríos",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Sebastián González Ríos",
    "email": "contact@sebasgrios.es",
    "url": "https://www.sebasgrios.es"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "wrangler pages dev dist",
    "check": "astro check && biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:types": "supabase gen types typescript --linked > src/lib/data/database.types.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-wasm": "^2.6.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^5.18.2",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.60.0",
    "sharp": "^0.34.5",
    "simple-icons": "^16.22.0",
    "vitest": "^2.1.9",
    "wrangler": "^4.97.0"
  },
  "packageManager": "pnpm@11.1.3"
}
