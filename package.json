{
  "name": "portfolio",
  "description": "Portfolio de Sebastián González Ríos",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Sebastián González Ríos",
    "email": "contact@sebasgrios.es",
    "url": "https://www.sebasgrios.es"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "wrangler pages dev dist",
    "check": "astro check && biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "db:types": "supabase gen types typescript --linked > src/lib/data/database.types.ts",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/cloudflare": "^12.2.1",
    "@astrojs/sitemap": "^3.2.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@resvg/resvg-wasm": "^2.6.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.1.1",
    "satori": "^0.26.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.49.1",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  },
  "packageManager": "pnpm@11.1.3"
}
